{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: server",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@effect-hello/server", "run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "^.*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "dev: web",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "web", "run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "^.*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "watch: shared",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@effect-hello/shared", "run", "watch"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*",
          "endsPattern": "^.*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true
      }
    },
    {
      "label": "dev: all (server + web + shared)",
      "dependsOn": ["watch: shared", "dev: server", "dev: web"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "build workspace",
      "type": "shell",
      "command": "pnpm build",
      "problemMatcher": []
    },
    {
      "label": "build server only",
      "type": "shell",
      "command": "pnpm build:server",
      "problemMatcher": []
    },
    {
      "label": "git commit and push",
      "type": "shell",
      "command": "git add . && git commit -m '更新保存' && git push",
      "group": "build"
    }
  ]
}
